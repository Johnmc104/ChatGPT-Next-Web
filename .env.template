# Your openai api key. (required)
OPENAI_API_KEY=sk-xxxx

# Access password, separated by comma. (optional)
CODE=your-password

# Override openai api request base url. (optional)
# Default: https://api.openai.com
# Examples: http://your-openai-proxy.com
BASE_URL=

# You can start service behind a proxy. (optional)
PROXY_URL=http://localhost:7890

# Specify OpenAI organization ID. (optional)
OPENAI_ORG_ID=

# Azure OpenAI (optional)
AZURE_URL=
AZURE_API_KEY=
AZURE_API_VERSION=

# Stability AI image generation (optional)
STABILITY_URL=
STABILITY_API_KEY=

# RAGFlow knowledge base (optional, server-side only)
RAGFLOW_URL=
RAGFLOW_API_KEY=

# Enable MCP functionality (optional)
# Default: Empty (disabled)
# Set to "true" to enable MCP functionality
ENABLE_MCP=

# (optional) If you do not want users to use GPT-4, set this value to 1.
DISABLE_GPT4=

# (optional) If you do not want users to input their own API key, set this value to 1.
HIDE_USER_API_KEY=

# (optional) If you do want users to query balance, set this value to 1.
ENABLE_BALANCE_QUERY=

# (optional) If you want to disable parse settings from url, set this value to 1.
DISABLE_FAST_LINK=

# (optional) To control custom models, use + to add a custom model, use - to hide a model, separated by comma.
CUSTOM_MODELS=

# (optional) Change default model
DEFAULT_MODEL=

# (optional) Additional vision-capable model names
VISION_MODELS=

# (optional) Allowed WebDAV endpoints
WHITE_WEBDAV_ENDPOINTS=

# (optional) Custom user input preprocessing template
DEFAULT_INPUT_TEMPLATE=
